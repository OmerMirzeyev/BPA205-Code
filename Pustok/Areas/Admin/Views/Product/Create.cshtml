@model Product
<div>
    <h1 class="text-primary">Add product</h1>
<form asp-controller="Product" asp-action="Create" method="post">

    <div class="form-group">
        <label for="title">Title</label>
        <input asp-for="@Model.Title" type="text" class="form-control" id="title" aria-describedby="emailHelp" placeholder="Add title...">
    </div>
    <div class="form-group">
        <label for="price">Price</label>
        <input asp-for="@Model.Price" type="number" class="form-control" id="price" aria-describedby="emailHelp" placeholder="Add price...">
    </div>
    <div class="form-group">
        <label for="imgUrl">ImageURL</label>
        <input asp-for="@Model.Image" type="text" class="form-control" id="imgUrl" aria-describedby="emailHelp" placeholder="Add imageURL...">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>
</div>